{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/product",
      "destination": "/product.html"
    },
    {
      "source": "/order",
      "destination": "/order.html"
    }
  ],
  "functions": {
    "api/charge.js": {
      "maxDuration": 30
    },
    "api/auth.js": {
      "maxDuration": 10
    },
    "api/send-email.js": {
      "maxDuration": 15
    },
    "api/init.js": {
      "maxDuration": 15
    },
    "api/products.js": {
      "maxDuration": 10
    },
    "api/orders.js": {
      "maxDuration": 10
    },
    "api/config.js": {
      "maxDuration": 10
    },
    "api/upload.js": {
      "maxDuration": 15
    },
    "api/order-lookup.js": {
      "maxDuration": 10
    }
  }
}
